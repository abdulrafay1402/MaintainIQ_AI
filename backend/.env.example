PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/maintainiq?retryWrites=true&w=majority
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=12h

# The deployed FRONTEND origin. QR codes and CORS both depend on this —
# in production set it to e.g. https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5173

# Google Gemini (AI triage + maintenance summaries). Get a free key at
# https://aistudio.google.com/apikey — without it, the rule-based fallback is used.
GEMINI_API_KEY=

# Gmail SMTP for OTP + notification emails (use an App Password)
SMTP_USER=
SMTP_PASS=

# Cloudinary (evidence image storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
